# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/docmind
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# AI API Keys (Choose one or both)
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here
AI_PROVIDER=openai  # or "gemini"

# GitHub
GITHUB_TOKEN=ghp_your-github-token-here
GITHUB_API_URL=https://api.github.com

# Application
APP_NAME=DocMind AI
APP_VERSION=1.0.0
DEBUG=True
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=True

# Security
SECRET_KEY=your-secret-key-here-change-in-production
API_KEY_HEADER=X-API-Key

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=docmind_embeddings

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Documentation Generation
MAX_FILE_SIZE_MB=10
MAX_REPOSITORY_SIZE_MB=500
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# LLM Settings
LLM_MODEL=gpt-4-turbo-preview  # or gemini-pro
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4000
LLM_STREAMING=True

# Background Jobs
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Feature Flags
ENABLE_PR_ANALYSIS=True
ENABLE_WEBHOOKS=True
ENABLE_ARCHITECTURE_DIAGRAMS=True
